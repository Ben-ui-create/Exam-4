<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Instagram</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial,Helvetica,sans-serif;
        }

        body{
            background:#fafafa;
        }

        header{
            position:sticky;
            top:0;
            background:#fff;
            border-bottom:1px solid #dbdbdb;
            padding:18px 40px;
            display:flex;
            justify-content:space-between;
            align-items:center;
            z-index:10;
        }

        .logo{
            font-size:34px;
            font-family:cursive;
        }

        .container{
            width:470px;
            margin:35px auto;
        }

        .post{
            background:#fff;
            border:1px solid #dbdbdb;
            border-radius:8px;
            margin-bottom:25px;
            overflow:hidden;
        }

        .post-header{
            display:flex;
            align-items:center;
            gap:12px;
            padding:14px;
        }

        .avatar{
            width:40px;
            height:40px;
            border-radius:50%;
            object-fit:cover;
            background:#ddd;
        }

        .username{
            font-weight:bold;
        }

        .post-image{
            width:100%;
            display:block;
        }

        .actions{
            display:flex;
            gap:12px;
            padding:14px;
        }

        .actions button{
            border:none;
            background:none;
            cursor:pointer;
            font-size:24px;
        }

        .likes{
            font-weight:bold;
            padding:0 14px 10px;
        }

        .caption{
            padding:0 14px 14px;
            word-break:break-word;
        }

        .comments{
            padding:0 14px 14px;
        }

        .comment{
            margin-bottom:6px;
            font-size:14px;
        }

        .comment strong{
            margin-right:6px;
        }

        .comment-form{
            border-top:1px solid #efefef;
            display:flex;
        }

        .comment-form input{
            flex:1;
            border:none;
            padding:15px;
            outline:none;
        }

        .comment-form button{
            border:none;
            background:none;
            color:#0095f6;
            font-weight:bold;
            padding:0 18px;
            cursor:pointer;
        }

        .comment-form button:hover{
            color:#1877f2;
        }
    </style>
</head>
<body>

<header>

    <div class="logo">
        Instagram
    </div>

</header>

<div class="container">

    <% posts.forEach(post => { %>

        <div class="post">

            <div class="post-header">

                <img
                        class="avatar"
                        src="<%= post.author.avatar || '/images/default-avatar.png' %>"
                        alt=""
                >

                <span class="username">
                    <%= post.author.username %>
                </span>

            </div>

            <img
                    class="post-image"
                    src="<%= post.image %>"
                    alt=""
            >

            <div class="actions">

                <form
                        action="/posts/<%= post.id %>/like"
                        method="POST"
                >
                    <button type="submit">
                        ❤️
                    </button>
                </form>

            </div>

            <div class="likes">
                <%= post.likesCount || 0 %> likes
            </div>

            <div class="caption">
                <strong><%= post.author.username %></strong>
                <%= post.caption %>
            </div>

            <div class="comments">

                <% post.comments.forEach(comment => { %>

                    <div class="comment">
                        <strong>
                            <%= comment.author.username %>
                        </strong>

                        <%= comment.text %>
                    </div>

                <% }) %>

            </div>

            <form
                    class="comment-form"
                    action="/posts/<%= post.id %>/comment"
                    method="POST"
            >

                <input
                        type="text"
                        name="text"
                        placeholder="Add a comment..."
                        required
                >

                <button type="submit">
                    Post
                </button>

            </form>

        </div>

    <% }) %>

</div>

</body>
</html>