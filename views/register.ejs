<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Instagram • Register</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, Helvetica, sans-serif;
        }

        body{
            background:#fafafa;
            display:flex;
            justify-content:center;
            align-items:center;
            min-height:100vh;
        }

        .container{
            width:360px;
        }

        .card{
            background:#fff;
            border:1px solid #dbdbdb;
            padding:35px 40px;
            text-align:center;
        }

        h1{
            font-size:42px;
            margin-bottom:15px;
            font-family:cursive;
        }

        .subtitle{
            color:#8e8e8e;
            margin-bottom:25px;
            font-size:14px;
            line-height:1.4;
        }

        .form-group{
            margin-bottom:10px;
        }

        label{
            display:none;
        }

        input{
            width:100%;
            padding:10px;
            border:1px solid #dbdbdb;
            background:#fafafa;
            border-radius:4px;
            font-size:14px;
        }

        .error-msg{
            display:block;
            color:#ed4956;
            font-size:12px;
            text-align:left;
            margin-top:3px;
            min-height:16px;
        }

        button{
            width:100%;
            padding:10px;
            margin-top:10px;
            border:none;
            border-radius:8px;
            background:#0095f6;
            color:#fff;
            font-weight:bold;
            cursor:pointer;
        }

        button:hover{
            background:#1877f2;
        }

        .footer{
            margin-top:12px;
            background:#fff;
            border:1px solid #dbdbdb;
            padding:20px;
            text-align:center;
        }

        a{
            color:#0095f6;
            text-decoration:none;
            font-weight:bold;
        }
    </style>
</head>
<body>

<div class="container">

    <div class="card">

        <h1>Instagram</h1>

        <p class="subtitle">
            Sign up to see photos and videos from your friends.
        </p>

        <form id="registerForm">

            <div class="form-group">
                <label for="name">Full Name</label>

                <input
                        type="text"
                        id="name"
                        name="name"
                        placeholder="Full Name"
                        required
                >

                <span class="error-msg" data-error="name"></span>
            </div>

            <div class="form-group">
                <label for="username">Username</label>

                <input
                        type="text"
                        id="username"
                        name="username"
                        placeholder="Username"
                        required
                >

                <span class="error-msg" data-error="username"></span>
            </div>

            <div class="form-group">
                <label for="email">Email</label>

                <input
                        type="email"
                        id="email"
                        name="email"
                        placeholder="Email"
                        required
                >

                <span class="error-msg" data-error="email"></span>
            </div>

            <div class="form-group">
                <label for="password">Password</label>

                <input
                        type="password"
                        id="password"
                        name="password"
                        placeholder="Password"
                        required
                >

                <span class="error-msg" data-error="password"></span>
            </div>

            <button type="submit">
                Sign up
            </button>

        </form>

    </div>

    <div class="footer">
        Have an account?
        <a href="/users/login">Log in</a>
    </div>

</div>

<script src="/js/register.js"></script>

</body>
</html>